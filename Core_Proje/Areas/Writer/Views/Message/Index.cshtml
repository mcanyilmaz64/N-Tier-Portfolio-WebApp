@using EntityLayer.Concrete
@model List<WriterMessage>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_WriterLayout.cshtml";
}

@* @{
	string color = "";
}
 *@

<div class="col-lg-12 grid-margin stretch-card">
	<div class="card">
		<div class="card-body">
			<h4 class="card-title">Gelen Kutusu</h4>
			<p class="card-description">
				Add class <code>.table</code>
			</p>
			<div class="table-responsive">
				<table class="table">
					<thead>
						<tr>
							<th>#</th>
							<th>Konu</th>
							<th>Gönderen</th>
							<th>Detaylar</th>
						</tr>
					</thead>
					<tbody>
						@foreach (var item in Model)
						{
							@* if (item.WriterMessageId == "Proje")
							{
								color = "badge badge-primary";
							}
							if (item.Status == "Blog")
							{
								color = "badge badge-success";

							}
							if (item.Status == "Video")
							{
								color = "badge badge-info";
							} *@
							<tr>
								<th>@item.WriterMessageId</th>
								<td>@item.Subject</td>
								<td>@((DateTime)item.Date).ToString("dd-MMM-yyyy")</td>
								<td> <a href="/Writer/Default/Details" class="badge badge-warning"> Detaylar </a></td>
							</tr>
						}

					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>

